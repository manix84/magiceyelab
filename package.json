{
  "name": "magiceyelab",
  "version": "3.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:dry-run": "npm run build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
